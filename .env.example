# AInalyst — шаблон переменных окружения
# Скопируйте в .env и заполните своими значениями:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Confluence — вариант A: Confluence Cloud (Atlassian)
# ---------------------------------------------------------------------------

CONFLUENCE_URL=https://your-domain.atlassian.net
CONFLUENCE_USERNAME=your@email.com
CONFLUENCE_API_TOKEN=your-api-token         # https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_CLOUD=true
CONFLUENCE_SPACE_KEY=BA                     # ключ пространства по умолчанию, например BA или PROJ

# ---------------------------------------------------------------------------
# Confluence — вариант B: Confluence Server / Data Center
# ---------------------------------------------------------------------------
# Раскомментируйте и заполните вместо варианта A.
# PAT поддерживается начиная с Confluence 7.9+.

# CONFLUENCE_URL=https://wiki.your-company.com
# CONFLUENCE_API_TOKEN=your-personal-access-token
# CONFLUENCE_CLOUD=false
# CONFLUENCE_SPACE_KEY=BA
